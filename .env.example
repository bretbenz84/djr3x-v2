# Host-specific hardware config — copy this file to .env and fill in real values.
# .env is excluded from git. Values differ per machine.
# Leave a value blank to gracefully disable that hardware feature.

# ReSpeaker Lite — USB microphone device index.
# Find the correct index with: python3 -c "import sounddevice as sd; print(sd.query_devices())"
AUDIO_DEVICE_INDEX=0

# Camera — ELP-USBFHD01M-L21 wide-angle USB camera mounted in Rex's head.
# Find the correct index with: python3 -c "import cv2; [print(i) for i in range(5) if cv2.VideoCapture(i).isOpened()]"
CAMERA_INDEX=0

# Pololu Maestro Mini 18 — servo controller, 9600 baud.
# Typical macOS path: /dev/tty.usbmodem<serial>
MAESTRO_PORT=/dev/tty.usbmodem00000000

# Arduino Uno — head LEDs (82 NeoPixels), 115200 baud.
# Shares the same usbmodem prefix class as the Maestro; use the correct serial number.
ARDUINO_HEAD_PORT=/dev/tty.usbmodem00000001

# Arduino Nano — chest LEDs (98 WS2811 LEDs), 115200 baud, CH340 USB-serial adapter.
# Typical macOS path: /dev/tty.usbserial-<id>
ARDUINO_CHEST_PORT=/dev/tty.usbserial-00000000
